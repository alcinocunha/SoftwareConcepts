<?xml version="1.0"?>
<alloy>

<view>

<defaultnode/>

<defaultedge/>

<node>
   <type name="Client"/>
   <type name="Int"/>
   <type name="M"/>
   <type name="R"/>
   <type name="Restaurant"/>
   <type name="SendConfirmation"/>
   <type name="String"/>
   <type name="univ"/>
   <type name="User"/>
   <type name="Messaging/Delete"/>
   <type name="Messaging/Messaging"/>
   <type name="Messaging/MessagingAction"/>
   <type name="Messaging/Read"/>
   <type name="Messaging/Send"/>
   <type name="Reservation/Cancel"/>
   <type name="Reservation/Provide"/>
   <type name="Reservation/Reservation"/>
   <type name="Reservation/ReservationAction"/>
   <type name="Reservation/Reserve"/>
   <type name="Reservation/Retract"/>
   <type name="Reservation/Use"/>
   <type name="seq/Int"/>
</node>

<node color="Green" label="tables">
   <set name="$tables" type="Table"/>
</node>

<node hideunconnected="yes">
   <type name="Messaging/Message"/>
</node>

<node numberatoms="no" color="Gray">
   <type name="Action/Action"/>
</node>

<node numberatoms="no" shape="Dbl Octagon" color="Red">
   <type name="Reaction/Reaction"/>
</node>

<node shape="Circle" color="White">
   <type name="Table"/>
</node>

<node visible="no">
   <type name="Action/Concept"/>
</node>

<edge attribute="no">
   <relation name="m"> <type name="Messaging/MessagingAction"/> <type name="Messaging/Message"/> </relation>
</edge>

<edge label="reservations">
   <relation name="$reservations"> <type name="Client"/> <type name="Table"/> </relation>
</edge>

<edge style="inherit" visible="no" attribute="yes">
   <relation name="c"> <type name="Reaction/Reaction"/> <type name="Client"/> </relation>
   <relation name="r"> <type name="Reservation/ReservationAction"/> <type name="Table"/> </relation>
</edge>

<edge visible="no">
   <relation name="c"> <type name="Action/Action"/> <type name="Action/Concept"/> </relation>
</edge>

<edge visible="no" attribute="yes">
   <relation name="content"> <type name="Messaging/Message"/> <type name="Table"/> </relation>
   <relation name="from"> <type name="Messaging/Message"/> <type name="User"/> </relation>
   <relation name="t"> <type name="Reaction/Reaction"/> <type name="Table"/> </relation>
   <relation name="to"> <type name="Messaging/Message"/> <type name="User"/> </relation>
   <relation name="u"> <type name="Messaging/MessagingAction"/> <type name="User"/> </relation>
   <relation name="u"> <type name="Reservation/Cancel"/> <type name="Client"/> </relation>
   <relation name="u"> <type name="Reservation/Reserve"/> <type name="Client"/> </relation>
   <relation name="u"> <type name="Reservation/Use"/> <type name="Client"/> </relation>
</edge>

</view>

</alloy>
