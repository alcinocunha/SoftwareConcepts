<?xml version="1.0"?>
<alloy>

<view>

<projection> <type name="Action/Concept"/> </projection>

<defaultnode/>

<defaultedge/>

<node>
   <type name="Chat"/>
   <type name="ChatAction"/>
   <type name="Content"/>
   <type name="Delete"/>
   <type name="Int"/>
   <type name="Join"/>
   <type name="Leave"/>
   <type name="Read"/>
   <type name="Send"/>
   <type name="String"/>
   <type name="univ"/>
   <type name="User"/>
   <type name="Action/Concept"/>
   <type name="ordering/Ord"/>
   <type name="seq/Int"/>
</node>

<node color="Gray">
   <type name="Action/Action"/>
</node>

<node color="Yellow">
   <set name="messages" type="Message"/>
</node>

<node hideunconnected="no" color="White">
   <type name="Message"/>
</node>

<node showlabel="no">
   <set name="$first" type="Time"/>
   <set name="$last" type="Time"/>
   <set name="$Scenario1_m" type="Message"/>
   <set name="$Scenario1_u" type="User"/>
   <set name="c" type="Action/Action"/>
</node>

<node visible="no">
   <type name="Time"/>
</node>

<node visible="yes" showlabel="no" shape="Ellipse" color="Green">
   <set name="time" type="Time"/>
</node>

<edge style="inherit">
   <relation name="joined"> <type name="Action/Concept"/> <type name="User"/> <type name="Time"/> </relation>
   <relation name="m"> <type name="Delete"/> <type name="Message"/> </relation>
   <relation name="m"> <type name="Read"/> <type name="Message"/> </relation>
   <relation name="m"> <type name="Send"/> <type name="Message"/> </relation>
   <relation name="messages"> <type name="Action/Concept"/> <type name="Message"/> </relation>
   <relation name="read"> <type name="Action/Concept"/> <type name="User"/> <type name="Message"/> </relation>
   <relation name="time"> <type name="Action/Concept"/> <type name="Time"/> </relation>
</edge>

<edge visible="no" attribute="yes">
   <relation name="content"> <type name="Message"/> <type name="Content"/> </relation>
   <relation name="from"> <type name="Message"/> <type name="User"/> </relation>
   <relation name="u"> <type name="Action/Action"/> <type name="User"/> </relation>
   <relation name="when"> <type name="Message"/> <type name="Time"/> </relation>
</edge>

</view>

</alloy>
